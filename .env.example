# Copy to .env for local overrides. Every value is optional.
# Branding lives in hub.config.json; these are runtime/deploy knobs.

# Port the live server listens on (default 5050).
PORT=5050

# Bind address. Containers set this to 0.0.0.0. Leave unset locally.
# HUB_HOST=0.0.0.0

# Optional HTTP basic auth for the whole site, format "user:pass".
# Off by default. The Hub is read-only; use this only if the host is reachable
# by people who should not see it.
# HUB_BASIC_AUTH=team:changeme

# Base path for the STATIC build (node build.js). Set to "/repo-name" for a
# GitHub Pages project site. Leave empty for root hosting (Netlify, Vercel, a
# custom domain). Overrides hub.config.json "basePath".
# HUB_BASE_PATH=/prototype-hub

# Override branding without editing hub.config.json (handy in CI).
# HUB_NAME=Acme Prototypes
# HUB_BRAND_COLOR=#4F46E5

# Point at a different config file.
# HUB_CONFIG=./hub.config.json
